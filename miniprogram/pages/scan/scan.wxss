/* pages/scan/scan.wxss */
page {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.content {
  width: 100%;
  max-width: 640rpx;
  background: white;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

/* 确认状态 */
.pet-greeting {
  margin-bottom: 50rpx;
}

.pet-avatar-large {
  font-size: 140rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.greeting-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.greeting-sub {
  font-size: 30rpx;
  color: #666;
}

.action-area {
  margin-bottom: 40rpx;
}

.action-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.feed-btn {
  width: 100%;
  height: 120rpx;
  line-height: 120rpx;
  background: linear-gradient(135deg, #FF9A56 0%, #FF6B6B 100%);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.4);
}

.feed-btn::after {
  border: none;
}

.feed-btn .btn-icon {
  font-size: 48rpx;
}

.feed-btn .btn-label {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.footer-hint {
  font-size: 24rpx;
  color: #bbb;
}

/* 成功状态 */
.success-content {
  padding-top: 50rpx;
}

.success-animation {
  margin-bottom: 40rpx;
}

.success-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  animation: scaleIn 0.5s ease-out;
}

@keyframes scaleIn {
  0% { transform: scale(0); opacity: 0; }
  80% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.success-icon {
  font-size: 80rpx;
  color: white;
  font-weight: bold;
}

.thanks-section {
  margin-bottom: 40rpx;
}

.thanks-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.thanks-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.thanks-text text {
  font-size: 30rpx;
  color: #666;
}

.record-detail {
  background: #f9f9f9;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.detail-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 28rpx;
  color: #999;
  margin-right: 16rpx;
}

.detail-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.detail-value.highlight {
  color: #FF6B6B;
  font-size: 40rpx;
  font-weight: bold;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
}

.action-btn.secondary {
  background: #f0f0f0;
  color: #666;
}

/* 错误状态 */
.error-content {
  padding: 80rpx 40rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
