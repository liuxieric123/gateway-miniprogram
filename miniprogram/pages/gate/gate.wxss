/* pages/gate/gate.wxss */
page {
  background-color: #F7F6F3;
  min-height: 100vh;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.nav-back {
  position: absolute;
  left: 10rpx;
  bottom: 0;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
}

.nav-back-icon {
  font-size: 40rpx;
  color: #37352F;
  font-weight: 700;
}

.nav-title-img {
  height: 36px;
  width: auto;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 无权限提示 */
.no-permission {
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  border-radius: 8rpx;
  padding: 80rpx 40rpx;
  text-align: center;
}

.lock-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.no-perm-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #37352F;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.no-perm-desc {
  font-size: 34rpx;
  color: #6B6B6B;
  margin-bottom: 30rpx;
}

.openid-box {
  margin-top: 30rpx;
  background: #F7F6F3;
  border: 1rpx solid #E9E9E7;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
}

.openid-label {
  font-size: 32rpx;
  color: #6B6B6B;
  margin-bottom: 16rpx;
}

.openid-value {
  font-size: 34rpx;
  color: #37352F;
  font-weight: 500;
  font-family: monospace;
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  word-break: break-all;
  user-select: text;
}

.openid-tip {
  font-size: 30rpx;
  color: #9B9B9B;
  margin-top: 20rpx;
}

/* 控制区域 */
.control-area {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  width: 100%;
}

.gate-btn {
  width: 100%;
  height: 380rpx;
  border-radius: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx;
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  transition: background 0.15s;
  animation: cardFloat 3s ease-in-out infinite;
}

.gate-btn::after {
  border: none;
}

.gate-btn:active {
  background: #EFEFEF;
}

.gate-btn[disabled] {
  opacity: 0.5;
}

.btn-open {
  animation-delay: 0s;
}

.btn-close {
  animation-delay: 0.5s;
}

.btn-icon-img {
  width: 240rpx;
  height: 240rpx;
}

.btn-text {
  font-size: 76rpx;
  font-weight: 700;
  color: #37352F;
  letter-spacing: 6rpx;
}

/* 临时链接入口 - 警示效果 */
.temp-link-bar {
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  border-radius: 32rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 20rpx;
  transition: background 0.15s;
  animation: warningPulse 3s ease-in-out infinite;
  position: relative;
}

.temp-link-bar:active {
  background: #EFEFEF;
}

.temp-link-icon {
  font-size: 38rpx;
  animation: warningShake 0.6s ease-in-out infinite;
  display: inline-block;
}

.temp-link-text {
  font-size: 30rpx;
  color: #37352F;
  font-weight: 600;
}

@keyframes warningPulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.4);
  }
  50% {
    box-shadow: 0 0 20rpx 8rpx rgba(255, 193, 7, 0.2);
  }
}

@keyframes warningShake {
  0%, 100% {
    transform: rotate(0deg);
  }
  20% {
    transform: rotate(-12deg);
  }
  40% {
    transform: rotate(12deg);
  }
  60% {
    transform: rotate(-8deg);
  }
  80% {
    transform: rotate(8deg);
  }
}

/* 临时链接弹窗 */
.temp-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  z-index: 1000;
}

.temp-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.temp-content {
  background: #FFFFFF;
  border-radius: 8rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.temp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #E9E9E7;
}

.temp-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #37352F;
}

.temp-close {
  font-size: 44rpx;
  color: #9B9B9B;
  padding: 10rpx;
}

.temp-body {
  padding: 30rpx;
}

.temp-hint {
  font-size: 32rpx;
  color: #6B6B6B;
  margin-bottom: 24rpx;
  text-align: center;
}

.temp-link-box {
  background: #F7F6F3;
  border: 1rpx solid #E9E9E7;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  color: #37352F;
  font-family: monospace;
  word-break: break-all;
  margin-bottom: 30rpx;
  user-select: text;
}

.temp-actions {
  display: flex;
  gap: 20rpx;
}

.temp-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: 1rpx solid #E9E9E7;
}

.temp-btn::after {
  border: none;
}

.temp-btn.copy {
  background: #FFFFFF;
  color: #37352F;
}

.temp-btn.copy:active {
  background: #EFEFEF;
}

.temp-btn.share {
  background: #F7F6F3;
  color: #37352F;
}

.temp-btn.share:active {
  background: #E9E9E7;
}
