/* pages/temp-gate/temp-gate.wxss */
page {
  background-color: #F7F6F3;
  min-height: 100vh;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 验证中 */
.checking {
  text-align: center;
}

.loading-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 34rpx;
  color: #6B6B6B;
}

/* 链接无效 */
.invalid {
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  border-radius: 36rpx;
  padding: 80rpx 50rpx;
  text-align: center;
  width: 100%;
}

.invalid-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.invalid-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #37352F;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.invalid-desc {
  font-size: 32rpx;
  color: #6B6B6B;
  line-height: 1.5;
}

/* 有效状态 */
.valid-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.countdown-bar {
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  border-radius: 36rpx;
  padding: 36rpx;
  text-align: center;
}

.countdown-label {
  font-size: 34rpx;
  color: #6B6B6B;
  display: block;
  margin-bottom: 12rpx;
}

.countdown-value {
  font-size: 64rpx;
  font-weight: 700;
  color: #37352F;
  font-family: monospace;
}

.hint {
  text-align: center;
  font-size: 32rpx;
  color: #6B6B6B;
  margin-bottom: 12rpx;
}

.gate-btn {
  width: 100%;
  height: 280rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border: 1rpx solid #E9E9E7;
  transition: background 0.15s;
  animation: cardFloat 3s ease-in-out infinite;
}

.gate-btn::after {
  border: none;
}

.gate-btn:active {
  background: #EFEFEF;
}

.gate-btn[disabled] {
  opacity: 0.5;
}

.btn-open {
  animation-delay: 0s;
}

.btn-close {
  animation-delay: 0.5s;
}

.btn-icon {
  font-size: 120rpx;
}

.btn-icon-img {
  width: 110rpx;
  height: 110rpx;
}

.btn-text {
  font-size: 52rpx;
  font-weight: 700;
  color: #37352F;
  letter-spacing: 4rpx;
}
